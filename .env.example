# Clave de Gemini (GRATIS) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opcional. Clave de VirusTotal (free) — https://www.virustotal.com/gui/my-apikey
# Sin ella, vt_lookup devuelve "no_consultado".
VT_API_KEY=

# Modelo Gemini del free tier. Por defecto gemini-2.5-flash.
VEREDICTUM_MODEL=gemini-2.5-flash
